APP_ENV=local
FLASK_DEBUG=1

# Choose database backend: auto, postgres, mysql, mariadb, or sqlite.
# - auto tries configured PostgreSQL/MySQL settings, then SQLite fallback if enabled.
# - postgres uses PostgreSQL settings.
# - mysql/mariadb uses MySQL settings.
DB_ENGINE=auto

# Optional: set DATABASE_URL to force one database and ignore DB_ENGINE.
# Examples:
# DATABASE_URL=sqlite:///instance/hotel_booking.sqlite3
# DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_booking
# DATABASE_URL=mysql://root:password@localhost:3306/hotel_booking
DATABASE_URL=

# Shared defaults used by either PostgreSQL or MySQL when engine-specific values are blank.
DB_HOST=localhost
DB_DATABASE=hotel_booking
DB_USERNAME=root
DB_PASSWORD=

# MySQL/MariaDB settings.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# PostgreSQL settings.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=hotel_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Local fallback when configured external databases are unavailable.
SQLITE_FALLBACK=1
SQLITE_PATH=instance/hotel_booking.sqlite3
